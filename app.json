{
  "expo": {
    "name": "Darna",
    "slug": "Darna",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/darna-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-splash-screen"
    ],
    "splash": {
      "image": "./assets/darna-splash-screen.png",
      "resizeMode": "cover",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.momen.ai.Darna"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/twensa-icon.png",
        "backgroundColor": "#0066CC"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.momen.ai.Darna"
    },
    "web": {},
    "extra": {
      "eas": {
        "projectId": "aac8a5f4-a5f1-4c24-ad18-7ec90d83ce7a"
      }
    }
  }
}
